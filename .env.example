# ── Mode ──────────────────────────────────────────────────
# Set to "true" to enable intelligent routing across multiple providers.
# When off (default), neonity uses a single provider set via DEFAULT_PROVIDER.
ROUTER_MODE=false

# ── Single-provider mode (when ROUTER_MODE=false) ─────────
DEFAULT_PROVIDER=deepseek

# ── Router mode (when ROUTER_MODE=true) ───────────────────
# Assign a provider to each cost tier. Tiers: cheap, standard, premium.
# If a tier has no provider configured, the router skips it.
#
# Routing logic:
#   - Simple one-shot queries (short, no tool history) → cheap tier
#   - High complexity keywords (refactor, debug, security...) → premium tier
#   - Multi-turn / tool-heavy tasks → premium tier
#   - Everything else → standard tier
#   - On failure: exponential backoff + circuit breaker + cross-tier fallback
#
# CHEAP_PROVIDER=deepseek
# CHEAP_MODEL=deepseek-v4-pro
# CHEAP_LABEL=DeepSeek V3  ← optional custom label
#
# STANDARD_PROVIDER=openai
# STANDARD_MODEL=gpt-4.1
#
# PREMIUM_PROVIDER=anthropic
# PREMIUM_MODEL=claude-sonnet-4-20250514

# ── Router tuning (all optional) ─────────────────────────
# ROUTER_VERBOSE=true           — log routing decisions to stderr
# ROUTER_TRACK_LATENCY=true     — record per-provider response times
# ROUTER_TRACK_BUDGET=true      — track cumulative token usage & cost
#
# Complexity strategy thresholds:
# ROUTER_COMPLEXITY_THRESHOLD=0.5   — keyword complexity score (0–1) that triggers premium
# ROUTER_COMPLEX_THRESHOLD=3000     — total char count that triggers premium
# ROUTER_TURN_THRESHOLD=5           — message count that triggers premium
# ROUTER_CHEAP_CHAR_LIMIT=500       — max chars for cheap short-circuit
#
# Circuit breaker:
# ROUTER_CIRCUIT_THRESHOLD=3        — consecutive failures before disabling a provider
# ROUTER_CIRCUIT_COOLDOWN=30000     — ms before retrying a disabled provider (half-open)

# ── API Keys (set the one(s) you need) ────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=

# ── Model overrides (optional, single-provider mode) ──────
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OPENAI_MODEL=gpt-4.1
# GEMINI_MODEL=gemini-2.5-flash
# DEEPSEEK_MODEL=deepseek-v4-pro
# MINIMAX_MODEL=MiniMax-M2.7
# MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic

# ── DeepSeek base URL (optional) ──────────────────────────
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Minimax base URL (optional) ───────────────────────────
# MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic

# ── Global settings ───────────────────────────────────────
# MAX_TOKENS=4096
# MAX_ITERATIONS=50
# TEMPERATURE=
# WORKING_DIRECTORY=

# ── Context window management ─────────────────────────────
# Strategy when context window fills: truncation (default) or summarization
# CONTEXT_STRATEGY=truncation
# CONTEXT_RESERVE_RATIO=0.25          — fraction of window reserved for output
# CONTEXT_PRESERVE_GROUPS=4           — recent message groups to always keep
# CONTEXT_WINDOW_SIZE=                — override auto-detected context window (tokens)
# CONTEXT_SUMMARIZATION_MODEL=        — model for summarization calls (defaults to same provider)

